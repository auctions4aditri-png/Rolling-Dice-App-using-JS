<!DOCTYPE html>
<html lang="en">
    <head>
        <title> Rolling Dice App using JS </title>

        <style>
            body {
                text-align: center;
                font-family: Helvetica, sans-serif;
            }

            #dice {
                font-size: 320px;
            }

            #dice:hover {
                cursor: pointer
            }
        </style>
    </head>

    <body>
        <div> Click on the dice... </div>
        <div id="dice" onclick="stopstart()"></div>

        <script>
            // dice image from values 1 to 6 are given in an array.
            var dices = ['&#9856;', '&#9857;', '&#9858;', '&#9859;', '&#9850;', '&#9861;'];
            var stopped = true;

            //for keep on changing the dice emojis
            function change() {
                var random = Math.floor(Math.random() * 6);
                dice.innerHTML = dices[random];
            }

            function stopStart() {
                if (stopped) {
                    stopped = false
                    // change function is called here to change the image for every 0.1 seconds
                    t = setInterval(change,100);
                } else {
                    clearInterval(t);
                    stopped = true;
                }
            }

            // invokiing function 
            window.onload = function() {
                dice = document.getElementById("dice")
                stopStart();
            }
        </script>
    </body>
</html>
