<!DOCTYPE html>
<html lang="en">
    <body>

        <h2 id="output">0</h2>

        <script>
            let count = 0;

            // Runs every 1 second (1000 ms)
            setInterval(function() {
                count++;
                document.getElementById("output").innerText = count;
            }, 1000);
        </script>
        
    </body>
</html>
